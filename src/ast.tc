// ####################################
// Unary Expressions
// ####################################
%node NotExpr UnaryExpr
toString(NotExpr){
    return "!" + expr->toString();
}
genCode(NotExpr){
    genResult exp = expr->genCode();
    stdstring t = newTemp();
    stdstring code = exp.code + t + " = icmp eq i64 " + exp.place + ", 0\n";
    return genResult(code, t);
}

%node NegExpr UnaryExpr
toString(NegExpr){
    return "-" + expr->toString();
}
genCode(NegExpr){
    genResult exp = expr->genCode();
    stdstring t = newTemp();
    stdstring code = exp.code + t + " = sub i64 0, " + exp.place + "\n";
    return genResult(code, t);
}

// ####################################
// Primaries
// ####################################
%node NumberVal Expr = {
    long value;
}
toString(NumberVal){
    return std::to_string(value);
}
genCode(NumberVal){
    stdstring t = newTemp();
    stdstring code = t + " = add i64 0, " + std::to_string(value) + "\n";
    return genResult(code, t);
}

%node IdVal Expr = {
    stdstring name;
}
toString(IdVal){
    return name;
}
genCode(IdVal){
    Symbol* sym = lookup(name);

    if(!sym){
        std::cerr << "Variable " + name + " Not Found";
        exit(1);
    }

    stdstring t = newTemp();
    stdstring code = t + " = load i64, i64* " + sym->addr + "\n";
    return genResult(code, t);
}

// ####################################
// Function Calls
// ####################################
%node FuncCall Expr = {
    stdstring id;
    ArgList *args;
}
toString(FuncCall){
    stdstring text = id + "(";

    if(args) {
        text += args->toString();
    }
    text += ")";

    return text;
}
genCode(FuncCall){
    // call i32 (i8*,...) @printf(i8* @.numStr, i64 %t9)
    return genCode();
}

%node ArgList Expr = {
    Expr *arg;
    ArgList *next;
}
toString(ArgList){
    if(next){
        return next->toString() + ", " + arg->toString();
    } else {
        return arg->toString();
    }
}
genCode(ArgList){
    genResult curr = arg->genCode();

    if(next != nullptr){
        genResult rest = next->genCode();

        stdstring code = curr.code + rest.code;
        stdstring place =  curr.place + ", " + rest.place;
        return genResult(code, place);
    }

    return curr;
}
