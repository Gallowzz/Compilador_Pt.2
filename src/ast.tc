// ####################################
// Unary Expressions
// ####################################
%node NotExpr UnaryExpr
toString(NotExpr){
    return "!" + expr->toString();
}
genExpr(NotExpr){
    genResult exp = expr->genExpr();
    stdstring t = newTemp();
    stdstring code = exp.code + t + " = icmp eq i64 " + exp.place + ", 0\n";
    return genResult(code, t);
}

%node NegExpr UnaryExpr
toString(NegExpr){
    return "-" + expr->toString();
}
genExpr(NegExpr){
    genResult exp = expr->genExpr();
    stdstring t = newTemp();
    stdstring code = exp.code + t + " = sub i64 0, " + exp.place + "\n";
    return genResult(code, t);
}

// ####################################
// Primaries
// ####################################
%node NumberVal Expr = {
    long value;
}
toString(NumberVal){
    return std::to_string(value);
}
genExpr(NumberVal){
    stdstring t = newTemp();
    stdstring code = t + " = add i64 0, " + std::to_string(value) + "\n";
    return genResult(code, t);
}

%node IdVal Expr = {
    stdstring name;
}
toString(IdVal){
    return name;
}
genExpr(IdVal){
    Symbol* sym = lookup(name);

    stdstring t = newTemp();
    stdstring code = t = " = load i64, i64* " + sym->addr + "\n";
    return genResult(code, t);
}
